{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "sortPackageJson": true,
  "sortImports": {
    "groups": [
      "builtin",
      "external",
      "internal",
      "subpath",
      "parent",
      "sibling",
      "index",
      "style",
      "unknown"
    ],
    "newlinesBetween": true
  },
  "ignorePatterns": ["**/dist", "**/tests/fixtures"]
}
