{
  "name": "@marcalexiei/oxlint-config",
  "version": "1.3.1",
  "description": "Custom oxlint config",
  "keywords": [
    "config",
    "format",
    "oxc",
    "oxlint"
  ],
  "homepage": "https://github.com/marcalexiei/void-0-configs/tree/main/packages/oxlint-config#readme",
  "license": "MIT",
  "author": "Marco Pasqualetti @marcalexiei",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcalexiei/void-0-configs.git",
    "directory": "packages/oxlint-config"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./base": "./dist/base.js",
    "./dom": "./dist/dom.js",
    "./typescript": "./dist/typescript.js",
    "./vitest": "./dist/vitest.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc",
    "rules:check": "node ./scripts/check-config.ts",
    "rules:write": "node ./scripts/write-config-rules.ts"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "oxlint": "catalog:dev",
    "oxlint-tsgolint": "catalog:dev"
  },
  "peerDependencies": {
    "oxlint": "catalog:peer",
    "oxlint-tsgolint": "catalog:peer"
  },
  "peerDependenciesMeta": {
    "oxlint-tsgolint": {
      "optional": true
    }
  }
}
